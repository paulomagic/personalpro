# Supabase - Configure suas credenciais
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Cloudflare Turnstile CAPTCHA (obtenha em https://dash.cloudflare.com/turnstile)
VITE_TURNSTILE_SITE_KEY=sua-site-key-aqui
# true = bloqueia login se CAPTCHA indisponível | false = fallback com auth-guard
VITE_CAPTCHA_STRICT_MODE=false
# true = bloqueia login/cadastro se auth-guard indisponível | false = fallback com lock local
VITE_AUTH_GUARD_STRICT_MODE=false

# AI Router model policy (Groq)
VITE_GROQ_MODEL_OPERATIONAL=llama-3.1-8b-instant
VITE_GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b
VITE_GROQ_MODEL_FALLBACK=mixtral-8x7b-32768
VITE_GROQ_MODEL_NARRATIVE=llama-3.3-70b-versatile

# ⚠️ Gemini API Key - NÃO MAIS NO FRONTEND!
# Configure via Supabase Secrets:
#   supabase secrets set GEMINI_API_KEY_PRIMARY=sua-chave-aqui
#   supabase secrets set GEMINI_API_KEY_FALLBACK=sua-chave-fallback
