{
  "name": "apex---premium-pt-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:functions": "tsc --noEmit -p tsconfig.functions.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:functions",
    "test:regression": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && printf '{\"type\":\"commonjs\"}' > .tmp-tests/package.json && node --test .tmp-tests/tests/**/*.test.js",
    "bundle:budget": "node scripts/check-bundle-budget.cjs",
    "secret-scan": "node scripts/secret-scan.cjs",
    "secret-scan:staged": "node scripts/secret-scan.cjs --staged",
    "security-check": "node scripts/security-check.cjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@marsidev/react-turnstile": "^1.4.1",
    "@supabase/supabase-js": "^2.89.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "glob": "^13.0.6",
    "lucide-react": "^0.562.0",
    "minimatch": "^10.2.2",
    "p-queue": "^9.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
