{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "supabase/functions/**/*.ts",
    "supabase/functions/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "organizacao-alteracoes-20260215"
  ]
}
